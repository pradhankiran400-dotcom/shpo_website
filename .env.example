# Database configuration
DATABASE_URL=sqlite:///./shop.db

# Admin Security Password (access to /admin dashboard)
ADMIN_PASSWORD=

# Gemini AI API Key for receipt forensics and chatbot
GEMINI_API_KEY=

# Google Maps API Key (Public key intentionally exposed client-side for Maps UI rendering)
GOOGLE_MAPS_API_KEY=

# Store UPI ID for merchant checkout payment QR codes
STORE_UPI_ID=

# Default phone number for active delivery agent dispatch tracking
DELIVERY_AGENT_PHONE=
